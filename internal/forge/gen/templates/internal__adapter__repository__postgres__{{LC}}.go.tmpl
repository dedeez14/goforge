package postgres

import (
	"context"
	"errors"

	"github.com/google/uuid"
	"github.com/jackc/pgx/v5"
	"github.com/jackc/pgx/v5/pgxpool"

	"{{.Module}}/internal/domain/{{.Lower}}"
	"{{.Module}}/pkg/dbx"
)

// {{.Name}}Repository is the pgx implementation of
// {{.Lower}}.Repository. It honours dbx.Audit on every write and
// applies a 'WHERE deleted_at IS NULL' clause to every read so the
// soft-delete flag is invisible to use cases.
type {{.Name}}Repository struct{ Pool *pgxpool.Pool }

// New{{.Name}}Repository wraps a pool.
func New{{.Name}}Repository(p *pgxpool.Pool) *{{.Name}}Repository { return &{{.Name}}Repository{Pool: p} }

func (r *{{.Name}}Repository) Create(ctx context.Context, v *{{.Lower}}.{{.Name}}) error {
	_, err := r.Pool.Exec(ctx, `
		INSERT INTO {{.Plural}} (id, name, created_at, updated_at, created_by, updated_by)
		VALUES ($1, $2, $3, $4, $5, $6)`,
		v.ID, v.Name, v.CreatedAt, v.UpdatedAt, v.CreatedBy, v.UpdatedBy,
	)
	return err
}

func (r *{{.Name}}Repository) FindByID(ctx context.Context, id uuid.UUID) (*{{.Lower}}.{{.Name}}, error) {
	row := r.Pool.QueryRow(ctx, `
		SELECT id, name, created_at, updated_at, deleted_at, created_by, updated_by, deleted_by
		FROM {{.Plural}}
		WHERE id = $1 AND deleted_at IS NULL`, id)
	v, err := scan{{.Name}}(row)
	if errors.Is(err, pgx.ErrNoRows) {
		return nil, {{.Lower}}.ErrNotFound
	}
	return v, err
}

func (r *{{.Name}}Repository) List(ctx context.Context, limit, offset int) ([]{{.Lower}}.{{.Name}}, error) {
	rows, err := r.Pool.Query(ctx, `
		SELECT id, name, created_at, updated_at, deleted_at, created_by, updated_by, deleted_by
		FROM {{.Plural}}
		WHERE deleted_at IS NULL
		ORDER BY created_at DESC
		LIMIT $1 OFFSET $2`, limit, offset)
	if err != nil {
		return nil, err
	}
	defer rows.Close()
	var out []{{.Lower}}.{{.Name}}
	for rows.Next() {
		v, err := scan{{.Name}}(rows)
		if err != nil {
			return nil, err
		}
		out = append(out, *v)
	}
	return out, rows.Err()
}

func (r *{{.Name}}Repository) Update(ctx context.Context, v *{{.Lower}}.{{.Name}}) error {
	_, err := r.Pool.Exec(ctx, `
		UPDATE {{.Plural}} SET name = $2, updated_at = $3, updated_by = $4
		WHERE id = $1 AND deleted_at IS NULL`,
		v.ID, v.Name, v.UpdatedAt, v.UpdatedBy,
	)
	return err
}

func (r *{{.Name}}Repository) SoftDelete(ctx context.Context, id uuid.UUID) error {
	actor, _ := dbx.ActorFromContext(ctx)
	_, err := r.Pool.Exec(ctx, `
		UPDATE {{.Plural}} SET deleted_at = now(), deleted_by = $2
		WHERE id = $1 AND deleted_at IS NULL`, id, actor,
	)
	return err
}

type scanner interface {
	Scan(dest ...any) error
}

func scan{{.Name}}(s scanner) (*{{.Lower}}.{{.Name}}, error) {
	var v {{.Lower}}.{{.Name}}
	if err := s.Scan(
		&v.ID, &v.Name,
		&v.CreatedAt, &v.UpdatedAt, &v.DeletedAt,
		&v.CreatedBy, &v.UpdatedBy, &v.DeletedBy,
	); err != nil {
		return nil, err
	}
	return &v, nil
}
