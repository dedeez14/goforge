{
    "name": "@dedeez14/goforge-client",
    "version": "0.1.0",
    "description": "TypeScript client SDK for goforge-based APIs. Auto-generated from openapi.json.",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "fetch": "node scripts/fetch-spec.mjs",
        "generate": "openapi-ts",
        "build": "tsc -p tsconfig.json",
        "clean": "rm -rf dist src/generated",
        "prepublishOnly": "npm run clean && npm run generate && npm run build"
    },
    "devDependencies": {
        "@hey-api/openapi-ts": "^0.53.0",
        "typescript": "^5.4.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dedeez14/goforge.git",
        "directory": "sdk/typescript"
    }
}
