# App
GOFORGE_APP_NAME=goforge
GOFORGE_APP_ENV=development
GOFORGE_APP_VERSION=0.1.0

# HTTP
GOFORGE_HTTP_HOST=0.0.0.0
GOFORGE_HTTP_PORT=8080
GOFORGE_HTTP_READ_TIMEOUT=10s
GOFORGE_HTTP_WRITE_TIMEOUT=15s
GOFORGE_HTTP_IDLE_TIMEOUT=60s
GOFORGE_HTTP_SHUTDOWN_TIMEOUT=15s
GOFORGE_HTTP_BODY_LIMIT_BYTES=1048576
GOFORGE_HTTP_PREFORK=false

# Database (PostgreSQL)
GOFORGE_DATABASE_DSN=postgres://goforge:goforge@localhost:5432/goforge?sslmode=disable
GOFORGE_DATABASE_MIN_CONNS=2
GOFORGE_DATABASE_MAX_CONNS=20
GOFORGE_DATABASE_MAX_CONN_LIFETIME=30m
GOFORGE_DATABASE_MAX_CONN_IDLE_TIME=5m
GOFORGE_DATABASE_CONNECT_TIMEOUT=5s
GOFORGE_DATABASE_STATEMENT_CACHE=true

# JWT (MUST be >= 32 chars in production, rotate regularly)
GOFORGE_JWT_SECRET=change-me-to-a-very-long-random-string-of-32+chars
GOFORGE_JWT_ISSUER=goforge
GOFORGE_JWT_ACCESS_TTL=15m
GOFORGE_JWT_REFRESH_TTL=168h

# Logging
GOFORGE_LOG_LEVEL=info
GOFORGE_LOG_PRETTY=true

# Security
GOFORGE_SECURITY_CORS_ALLOW_ORIGINS=*
GOFORGE_SECURITY_RATE_LIMIT_PER_MIN=120
GOFORGE_SECURITY_TRUST_X_FORWARDED=false
